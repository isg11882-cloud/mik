# ──────────────────────────────────────────
# 재회컨설팅 앱 환경변수 샘플 (.env.example)
# .env.local 로 복사 후 실제 값을 입력하세요.
# ──────────────────────────────────────────

# [AI] Google Gemini API Key (Google AI Studio에서 발급)
GOOGLE_AI_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx

# [AI] 사용할 모델 ID (선택 사항, 기본값: gemini-flash-latest)
# GEMMA_MODEL_ID=gemini-1.5-flash

# [Database/Auth] Supabase 설정
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxx

# [Database/Admin] service_role 키 — Supabase Dashboard > Project Settings > API > service_role
# ⚠️ 절대 NEXT_PUBLIC_ 접두어를 붙이지 마세요. 클라이언트 번들에 포함되면 RLS 가 무력화됩니다.
# Phase 3 의 AI 모더레이터/관리자 작업 등 서버 전용 로직에서만 사용.
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# [App] 애플리케이션 URL
NEXT_PUBLIC_APP_URL=http://localhost:3000
